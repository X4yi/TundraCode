{
  "identifier": "default",
  "description": "Default capabilities for TundraCode",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "shell:allow-open",
    "dialog:allow-open"
  ]
}
